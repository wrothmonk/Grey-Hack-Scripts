UserOptions["setup"] = {"enabled":true, "name":"SSH into a system and secure it"}
UserOptions.secure["func"] = function()
  print("Enter IP and root password to connect")
  print("If ssh not on port 22 enter ip as <b>ip:port</b>")
  connected = false
  while not connected
    //Attempt connection
    ip = user_input("IP: ")
    pass = user_input("Root pass: ", true)
    PASSWORDS[ip] = "root:" + pass

    remote_shell = connect(ip)
    if not remote_shell then //connection error occured
      PASSWORDS.remove(ip) //Remove incorrect entry
      input = user_input("Try again? (y/n):")
      if Input != "y" then
        print("Canceled")
        return //exit function
      end if
    else
      connected = true
    end if

  end while

  print("\nChmoding system...")
  remote_computer = remote_shell.host_computer
  root_folder = remote_computer.File("/")
  root_folder.chmod("o-wrx", true)
  root_folder.chmod("g-wrx", true)
  root_folder.chmod("u-wrx", true)
  root_folder.set_owner("root", true)
  root_folder.set_group("root", true)

  print("Generating new Root password...")
  new_pass = genPassword()
  remote_computer.change_password("root", new_pass)
  PASSWORDS[ip] =  "root:" + new_pass

  print("Saving password...")
  selfCompile()

  print("Done!")
end function

UserOptions["exit"] = {"enabled":true, "name":"Exit"}
UserOptions.exit["func"] = function()
  selfCompile() //Each function should save changes when necessary, this is just in case
  exit()
end function


userLoop = function()
  while true
    clear_screen
    print("<b>Passman v1.0.0</b>")

    remote_str = ""
    if ENABLE_REMOTE then
      remote_str = "<color=green>ENABLED</color=green>"
    else
      remote_str = "<color=red>DISABLED</color=red>"
    end if
    print("Remote access: " + remote_str)

    options = []
    for option in UserOptions.indexes
      if UserOptions[option].endabled then
        options.push(option)
        print(options.len + ": " + option.name)
      end for
    end for

    print("\n")
    selection = to_int(user_input("Run option: ")) - 1
    if selection >= 0 and selection < options.len then
      clear_screen
      UserOptions[options[selection]].func()
    end if
  end while
end function


//Main function

main = function()
  if TOKEN == "" then

    if not active_user == "root" then
      exit("passman must be initialized as root!")
    end if

    print("Changing root password...")
    ROOT = genPassword()
    Computer.change_password("root", ROOT)
    print("Your new root password is: " + ROOT)

    TOKEN = genToken()
    selfCompile() //compile with new token
    print("Your passman token is: <b>" + token + "</b>")
    print("Restarting...")

    Shell.launch("/bin/passman", "/root") //Launch new version of self
  else if params.len >= 1 and params[0] != TOKEN then //remote calling
    if params[0] == TOKEN then
      remoteCall(params[1], params[2])
    else
      exit()
    end if
  else //User calling

    //Make sure passman was launched as root
    if active_user != "root" then
      exit("Passman must be launched as root or it will not funtion properly!")
    end if

    input = user_input("Password: ", true)
    if input == TOKEN then
      userLoop()
    else
      exit()
    end if
  end if
end function

main()
