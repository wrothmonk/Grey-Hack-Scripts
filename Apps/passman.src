//Checks if entry name is an IP (Could be normal IP or IP:Port pair)
is_ip_entry = function(name)
  if is_valid_ip(name) or is_valid_ip(name.split(":")[0]) then
    return true
  else
    return false
  end if
end function

UserOptions["view"] = {"enabled":PASSWORDS.len > 0, "name":"View saved passwords"}
UserOptions.view["func"] = function()
  //Seperate password entries and IP entries
  passwords = []
  IPs = []
  for pass in PASSWORDS.indexes
    if is_ip_entry(pass) then
      IPs.push(pass)
    else
      passwords.push(pass)
    end if
  end for

  both = IPs + passwords

  view = function(list)
    for i in range(1, list.len)
      print(i + ": " + list[i])
    end for
    selection = to_int(user_input("View password for: "))
    if typeof(selection) == "number" and selection <= list.len then
      index = selection - 1
      print(list[index] + ": " + PASSWORDS[list[index]])
      user_input("Press enter to continue")
    end if
  end function

  print("Enter the entry name or one of the numbers for the following")
  print("1: General Entries")
  print("2: SSH Entries")
  print("3: Both\n")

  selection = user_input("View: ")
  if selection == "1" then
    view(passwords)
  else if selection == "2" then
    view(IPs)
  else if selection == "3" then
    view(both)
  else
    results = searchPasswords(name)

    if results.len == 1 then //one exact match, or only a single simple match
      print(name + ": " + PASSWORDS[selection])
    else if results.len == 0 then
      print("No matches found for: " + selection)
    else
      print("Multiple results found:\n")
      view(results)
    end if

  end if
end function

//Test if there are any IP address entries
passmanHasIPs = function() //Used for determining if ssh should be enabled
  for name in PASSWORDS.indexes
    if is_ip_entry(name) then
      return true
    end if
  end for
  return false
end function

