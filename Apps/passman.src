PASSWORDS = {}
TOKEN = ""
ROOT = ""
ENABLE_REMOTE = false

//Only edit past this point
Shell = get_shell
Computer = Shell.host_computer



//Remote access functions

//Function for inserting into other programs to run passman remotely
runPassman = function(shell, pass_name)
  token = ""
  pad_str = ""
  pad = []
  //generate pad
  for i in range(1, 15) //password length
    num = floor((rnd * 65535) + 0.5) //integer between 0 and 65535
    pad_str = pad_str + num + ":"
    pad.push(num)
  end for
  pad_str = pad_str[:pad_str.len-1] //remove extra ":" at end

  //run passman
  args = token + " " + pad_str + " " + pass_name
  result = shell.launch("/bin/passman", args)
  if result == false then //shell.launch returns false on failure, null on success?
    return false //allow error handling on other program
  end if

  //Retrieve and delete output file
  file = shell.host_computer.File("/home/guest/passman.txt")
  output = file.content
  //send delete command to passman to remove file
  shell.launch("/bin/passman", token + " DELETE")

  //decrypt content
  decrypted = ""
  for i in range(0, output.len - 1)
  	num = output[i].code
  	num = num - 1 //move to 0 - 65535 range
  	num = num - pad[i] // remove pad character
  	if num < 0 then
  		num = num + 65535 //undo modulus
  	end if
  	num = num + 1 //move back to 1 - 65536 range
  	decrypted = decrypted + char(num)
  end for

  if decrypted != "null" then //"null" means there is no password saved under pass_name
    return decrypted
  end if
end function

//Responding side of runPassman function
remoteCall(pad_str, pass_name)
  if not Computer.File("/home/guest").has_permission("w") then //not root
    root = get_shell("root", ROOT)
    root.launch("/bin/passman", TOKEN + " " + pad_str + " " + pass_name) //re-launch as root
  end if

  if pad_str == "DELETE" then //delete command called
    file = Computer.File("/home/guest/passman.txt")
    if typeof(file) != "null" then
      file.delete
    end if
  end if

  //get password
  pass = "null" //No result str
  if ENABLE_REMOTE and PASSWORDS.hasIndex(pass_name) then
    pass = PASSWORDS[pass_name]
  end if

  //encrypt password
  encrypted = ""
  pad = pad_str.split(":")
  for i in range(0, pad.len - 1)
    pad[i] = to_int(pad[i]) // convert number strings to ints
  end for
  for i in range(0, pass.len - 1)
    num = pass[i].code - 1 //move code to be between 0 and 65535
    num = (num + pad[i]) % 65536 //encrypt with pad character
    num = num + 1 //Put back into 1 - 65536 range
    encrypted = encrypted + char(num)
  end for

  //copy to guest access file
  Computer.touch("/home/guest/passman.txt")
  file = Computer.File("/home/guest/passman.txt")
  //secure the file
  file.chmod("o-rwx")
  file.chmod("u-rwx")
  file.chmod("g-rwx")

  file.set_content(encrypted)
  //make sure file will be readable
  file.chmod("u+r")
  file.set_owner("guest")
  exit()
end function



//Password generation functions

//Generic generation of a password
genPass = function(dict, len)
  pass = ""
  for i in range(1, len)
    dict.shuffle
    pass = pass + char(dict[0])
  end for

  return pass
end function

//Generates a password usable for user passwords
genPassword = function()
  dict = range(48, 57) + range(65, 90) + range(97, 122) //Alpha-Numeric
  return genPass(dict, 15)
end function

//Generates a 30 character token used for added security of running programs
genToken = function()
  //Characters, numbers, and symbols. Excludes qoute symbol since that just gets complicated.
  dict = [33] + range(35, 126)
  return genPass(dict, 30)
end function



//Compiling functions

joinLines = function(lines)
  str = ""
  for line in lines
    str = str + line + "\n"
  end for
  str = str[:str.len - 1] //remove extra newline at end
  return str
end function

//Finds the start and end lines of the runPassman function in a given src str
findPassmanFunction(src)
  lines = src.split("\n")
  func_start = -1
  func_end = -1
  for i in range(0, lines.len)
    if lines[i].indexOf("runPassman = function(shell, pass_name)") == 0 then
      func_start = i
    else if func_start > -1 and lines[i].indexOf("end function") == 0 then
      func_end = i
      break
    end if
  end for
  return [func_start, func_end]
end function

//overwrite runPassman function in src with copy from own src
precompile = function(src)
  indexes = findPassmanFunction(src)
  pre_func = lines[:indexes[0]]
  post_func = lines[indexes[1] - 1:] //-1 to include "end function" line

  self_src = getOwnSource().content
  indexes = findPassmanFunction(self_src)
  lines = self_src.split("\n")
  func_lines = lines[indexes[0]+1:indexes[1]]
  func_lines[0] = char(9) + "token = """ + TOKEN + """" //insert passman token

  return joinLines(pre_func + func_lines + post_func)
end function

//converts a str:str map into a single long string (used for saving passwords to binary)
mapToStr = function(map)
	output = "{"
	for pair in map
		if typeof(pair.key) != "string" or typeof(pair.value) != "string" then
			print("<color=red>Error in mapToStr, expected str:str map")
			print("<color=red>Input map:" + char(10))
			exit(map)
		end if

		output = output + """" + pair.key + """:""" + pair.value + ""","
	end for
	output = output[:output.len - 1] //Remove trailing ","
	output = output + "}"
	return output
end function

//Get passman's own sourcecode
getOwnSource = function()
  file = Computer.File("/bin/passman.src")
  if typeof(file) == "null" then
    print("<b><color=red>Could not find source file for passman!!!")
    input = user_input("Print out passwords for recovery? (y/n)\n")
    if input == "y" or input == "yes" then
      for pair in PASSWORDS
        print(pair.key + ": " + pair.value)
      end for
    end if
    exit("Failed to find src, any recent changes have been lost")
  end if
  return file
end function

selfCompile = function()
  src_file = getOwnSource()
  original = src_file.content
  copy = original
  //Replace TOKEN, PASSWORDS, ROOT, and ENABLE_REMOTE in copy with current values
  replacements = {"PASSWORDS = {}":PASSWORDS, "TOKEN = """"":TOKEN, "ROOT = """"":ROOT, "ENABLE_REMOTE = false":ENABLE_REMOTE}
  lines = copy.split("\n")

  for line in lines
    if replacements.hasIndex(line) then
      index = line.lastIndexOf("= ")
      //replace value
      lines[lines.indexOf(line)] = line[:index+2] + replacements[line]
      replacements.remove(line) //Remove index so loop can break once all matches made
      if replacements.len == 0 then
        break
      end if
    end if
  end for

  copy = joinLines(lines)
  src_file.set_content(copy)
  Shell.build(src_file.path, "/bin")
  //change src file back as soon as possible to minimize possibility of sensitive information leaking
  src_file.set_content(original)

  new_version = Computer.file("/bin/" + src_file.name[:-4])
  //Newly compiled executables get default permissions, need to chmod
  new_version.chmod("o-rwx")
  if ENABLE_REMOTE then
    new_version.chmod("o+x") //Allow remote execution
  end if
  new_version.chmod("g-rwx")
  new_version.chmod("u-rwx")
end function



//User Functions

UserOptions = {}

UserOptions["disableRemote"] = {"enabled":ENABLE_REMOTE, "name":"Disable remote access"}
UserOptions.disableRemote["func"] = function()
  ENABLE_REMOTE = false
  print("Remote access disabled, saving change...")
  selfCompile()
end function

UserOptions["enableRemote"] = {"enabled":not ENABLE_REMOTE, "name":"Enable remote access"}
UserOptions.enableRemote["func"] = function()
  ENABLE_REMOTE = true
  print("Remote access enabled, saving change...")
  selfCompile()
end function

UserOptions["regenToken"] = {"enabled":true, "name":"Change passman token"}
UserOptions.regenToken["func"] = function()
  print("WARNING: This will invalidate any access by programs previously precompiled by this passman instance!")
  confirmation = user_input("Confirm change? (y/n): ")
  if confirmation == "y" then
    new_token = genToken()
    TOKEN = new_token
    print("Saving new token...")
    selfCompile()
    print("Your new login token is: <b>" + new_token)
    user_input("Press enter to restart passman once you have saved your new token\n")
    Shell.launch("/bin/passman", "/root")
  end if
end function

UserOptions["save"] = {"enabled":true, "name":"Save a password"}
UserOptions.save["func"] = function()
  print("Input name and password")
  print("Names that are valid IP addresses will have their password used as user:pass combinations for SSH-ing into")
  pass_name = user_input("Name:")

  if PASSWORDS.hasIndex(pass_name) then
    print("<b>" + pass_name + " is already in passman!")
    confirm = user_input("Overwrite? (y/n): ")
    if not confirm == "y" then
      return //exit saving function
    end if
  end if

  done = false
  while not done
    pass1 = user_input("Password:", true)
    pass2 = user_input("Confirm:", true)
    if pass1 != pass2 then
      print("<color=red>Password did not match! Try again.")
    else
      done = true
    end if
  end while

  PASSWORDS[pass_name] = pass1
  print("Saving changes...")
  selfCompile()
end function

//Searches through PASSWORDS for full or partial matches
searchPasswords = function(name)
  results = []
  for name in PASSWORDS.indexes
    if name == selection then
      //return single result since it's an exact match
      results = [name]
      break
    else if typeof(name.indexOf(selection)) != "null" then //simple match
      results.push(name)
    end if
  end for
  return results
end function

//Not sure why delete comes up as a keyword, capitalized to avoid
